# ============================================================================
# DNA診断AI — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を設定する。
# .env.local は .gitignore で除外済み。絶対にコミットしないこと。
# ============================================================================

# ---- Supabase --------------------------------------------------------------
# プロジェクト URL (例: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon key (RLS適用下で公開可能なキー。ブラウザに露出してOK)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key (RLSバイパス。サーバ専用。絶対にクライアント露出禁止)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic (Claude API) ------------------------------------------------
# 統合エンジン (Sonnet 4.6) ・分身ボット用
ANTHROPIC_API_KEY=

# ---- Resend (メール送信) ---------------------------------------------------
RESEND_API_KEY=

# 送信元 (DNS認証済みドメインのアドレス推奨)
# 例: "DNA診断AI <noreply@dna-shindan.ai>"
RESEND_FROM="DNA診断AI <noreply@dna-shindan.ai>"

# 返信先 (ユーザーが返信した時の宛先)
RESEND_REPLY_TO=yoisno@gmail.com

# ---- Google Sheets API (YOスプシ集約) --------------------------------------
# サービスアカウントの client_email
GOOGLE_SHEETS_CLIENT_EMAIL=

# サービスアカウントの private_key (改行は \n のままでOK。コード側で復元する)
GOOGLE_SHEETS_PRIVATE_KEY=

# 集約先スプレッドシートID
GOOGLE_SHEET_ID=

# 集約先シート名 (タブ名)
GOOGLE_SHEET_TAB_NAME=diagnoses

# Sentry — 未設定時は no-op（無料枠を消費しない）
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXX.ingest.sentry.io/XXXXX
# SENTRY_DSN=同上
